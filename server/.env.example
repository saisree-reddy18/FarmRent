# =====================================================
# FarmRent Server Configuration
# Copy this file to .env and fill in your values
# Then run:  node server.js
# =====================================================

# ----- GMAIL (Recommended - easiest setup) -----------
# Your Gmail address
GMAIL_USER=yourname@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Steps to get it:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search for "App passwords" in the search bar
#   4. Create app → name it "FarmRent" → copy the 16-char password
GMAIL_PASS=abcd efgh ijkl mnop

# ----- DEVELOPMENT MODE (no email needed) ------------
# Set to 1 to auto-fill OTP in the browser (for testing only)
# FR_DEV_OTP=1

# ----- OTHER SETTINGS --------------------------------
# JWT secret key (change this to something random in production)
FR_SECRET=change_this_to_something_random

# Server port (default: 4000)
# PORT=4000
